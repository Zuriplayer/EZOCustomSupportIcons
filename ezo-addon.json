{
  "schemaVersion": 1,
  "addon": {
    "id": "ezocustomsupporticons",
    "name": "EZOCustomSupportIcons",
    "version": "0.3.5",
    "status": "alpha",
    "phase": "independent-renderer",
    "visibility": "private",
    "manifest": "EZOCustomSupportIcons.txt",
    "package": {
      "rootFolderName": "EZOCustomSupportIcons",
      "zipName": "EZOCustomSupportIcons_v0.3.5.zip",
      "outputPath": "dist",
      "include": [
        "*.txt",
        "*.lua",
        "modules/**",
        "icons/**"
      ],
      "exclude": [
        ".codex/**",
        ".github/**",
        ".git/**",
        ".vscode/**",
        "dev/**",
        "docs/**",
        "packs/**",
        "scripts/**",
        "tests/**",
        "test/**",
        "node_modules/**",
        "build/**",
        "dist/**",
        "*.md",
        "*.ps1",
        "*.sh",
        "*.log",
        "*.tmp",
        "*.bak"
      ]
    }
  },
  "discord": {
    "webhookSecretNames": {
      "downloads": "EZO_CODEX_DOWNLOADS",
      "releases": "EZO_CODEX_RELEASES",
      "status": "EZO_CODEX_STATUS",
      "announcements": "EZO_CODEX_ANNOUNCER",
      "betaBuilds": "EZO_CODEX_BETA_BUILDS",
      "codexLog": "CODEX_LOG",
      "bugReports": "EZO_CODEX_BUG_REPORTS"
    }
  }
}
